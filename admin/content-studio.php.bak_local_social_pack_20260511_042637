<script>
(function(){
  function getContentId(){
    const params = new URLSearchParams(window.location.search);
    return params.get('id') || params.get('content_id') || params.get('edit') || '';
  }

  const contentId = getContentId();
  if (!contentId) return;

  if (document.getElementById('wmCreativeImageUrlBox')) return;

  const box = document.createElement('section');
  box.id = 'wmCreativeImageUrlBox';
  box.className = 'card';
  box.style.marginBottom = '16px';
  box.innerHTML = `
    <h3 style="margin-top:0">Instagram Creative Image</h3>
    <div style="font-size:13px;color:#667085;margin-bottom:10px">
      Paste public HTTPS image URL for this post. Instagram will use this instead of fallback logo.
    </div>
    <input
      type="url"
      id="wmCreativeImageUrlInput"
      placeholder="https://wealthmetre.com/images/your-creative.png"
      style="width:100%;padding:11px 12px;border:1px solid #d0d5dd;border-radius:10px;font-size:14px;margin-bottom:10px"
    />
    <button
      type="button"
      id="wmSaveCreativeImageUrlBtn"
      style="padding:10px 14px;border:0;border-radius:10px;background:#0b5fff;color:white;font-weight:700;cursor:pointer"
    >
      Save Creative URL
    </button>
    <span id="wmCreativeImageUrlMsg" style="margin-left:10px;font-size:13px"></span>
  `;

  const target =
    document.querySelector('main') ||
    document.querySelector('.main') ||
    document.querySelector('.content') ||
    document.querySelector('.container') ||
    document.body;

  target.insertBefore(box, target.firstChild);

  const input = document.getElementById('wmCreativeImageUrlInput');
  const btn = document.getElementById('wmSaveCreativeImageUrlBtn');
  const msg = document.getElementById('wmCreativeImageUrlMsg');

  fetch('/api/social/creative_image_url.php?id=' + encodeURIComponent(contentId))
    .then(r => r.json())
    .then(j => {
      if (j.ok && j.creative_image_url) input.value = j.creative_image_url;
    })
    .catch(() => {});

  btn.addEventListener('click', function(){
    const url = input.value.trim();

    if (url && !url.startsWith('https://')) {
      msg.style.color = '#b42318';
      msg.textContent = 'URL must start with https://';
      return;
    }

    btn.disabled = true;
    msg.style.color = '#667085';
    msg.textContent = 'Saving...';

    const fd = new FormData();
    fd.append('id', contentId);
    fd.append('creative_image_url', url);

    fetch('/api/social/creative_image_url.php', {
      method: 'POST',
      body: fd
    })
    .then(r => r.json())
    .then(j => {
      if (j.ok) {
        msg.style.color = '#027a48';
        msg.textContent = 'Saved';
      } else {
        msg.style.color = '#b42318';
        msg.textContent = j.error || 'Save failed';
      }
    })
    .catch(() => {
      msg.style.color = '#b42318';
      msg.textContent = 'Save failed';
    })
    .finally(() => {
      btn.disabled = false;
    });
  });
})();
</script>


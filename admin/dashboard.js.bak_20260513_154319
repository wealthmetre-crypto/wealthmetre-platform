      <td><span style="font-family:monospace;font-size:12px">${maskMobile(l.mobile)}</span></td>
      <td style="font-size:12px">${l.city||'—'}</td>
      <td><span class="badge b-navy" style="font-size:10px">${l.loan_type||'—'}</span></td>
      <td style="font-size:12px;font-weight:600">${l.loan_amount ? '₹'+fmtNum(parseInt(l.loan_amount)/100000)+'L' : '—'}</td>
      <td style="font-size:11.5px">${l.partner_name||'—'}</td>
      <td><span class="badge ${statusColors[l.status]||'b-pending'}">${l.status||'New'}</span></td>
      <td style="font-size:11px">${l.followup_date ? fmtDate(l.followup_date) : '—'}</td>
      <td><span class="badge b-purple" style="font-size:9.5px">${l.source||'Upload'}</span></td>
      <td><div class="td-actions">
        <button class="btn btn-outline btn-xs" onclick="openCrmLead(JSON.parse(this.closest('tr').dataset.l))"><i class="fa fa-eye"></i></button>
      </div></td>
    </tr>`).join('');
    document.getElementById('leadsInfo').textContent = r.data.length + ' leads for ' + name;
  } catch(e) { tbody.innerHTML = '<tr><td colspan="11" style="text-align:center;padding:24px;color:var(--red)">Error</td></tr>'; }
}
async function markFollowupDone(id, btn) {
  btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
  try {
    const r = await fetch(API, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({action:'update_lead_status', id, status:'Callback', followup_done:1})
    }).then(d=>d.json());
    if (r.success) {
      toast('Follow-up marked as done', 'success');
      btn.closest('tr').style.opacity = '0.4';
    } else toast(r.message||'Failed', 'error');
  } catch(e) { toast('Error','error'); }
  btn.disabled = false;
}
function showMissingFields(missing, lenderName) {
  const fieldLabels = {
    'roi_min':'ROI Min %', 'max_ltv':'Max LTV %', 'min_cibil':'Min CIBIL',
    'max_foir_pct':'Max FOIR %', 'property_types':'Property Types',
    'city_coverage':'City Coverage', 'income_types':'Income Types',
    'sales_manager_name':'Sales Manager', 'processing_fee_pct':'Processing Fee %',
    'surrogate_programs':'Surrogate Programs'
  };
  showConfirm(
    '📋 Missing Fields: ' + lenderName,
    '',
    () => openLenderDetail(0)
  );
  document.getElementById('confirmMsg').innerHTML =
    '<div style="font-size:13px;color:var(--text-soft);margin-bottom:10px">These fields are missing or empty:</div>'
    + missing.map(f => `<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border)">
        <i class="fa fa-circle-xmark" style="color:var(--red)"></i>
        <span style="font-size:13px;font-weight:600">${fieldLabels[f]||f.replace(/_/g,' ')}</span>
      </div>`).join('')
    + '<div style="margin-top:12px;font-size:12px;color:var(--muted)">Click "Fix Now" to open the lender editor</div>';
  document.getElementById('confirmOkBtn').textContent = 'Fix Now';
  document.getElementById('confirmOkBtn').onclick = () => {
    closeModal('confirmModal');
    openLenderDetail(window._lastQualityId);
  };
}

// ═══ FOLLOW-UPS ═══
async function filterFollowups(type) {
  let tbody = document.getElementById('followupsTable');
  tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--muted)"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>';
  try {
    let r = await fetch(`${API}?action=followups_list&type=${type}`, {credentials:'include'}).then(d=>d.json());
    if (!r.success || !r.data.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--muted)">No follow-ups found</td></tr>'; return; }
    const today = new Date(); today.setHours(0,0,0,0);
    tbody.innerHTML = r.data.map(f => {
      const fdate = new Date(f.followup_date);
      const overdue = fdate < today;
      const daysDiff = Math.round((today-fdate)/(1000*60*60*24));
      return `<tr>
        <td><div class="name-cell">${f.name||'—'}</div></td>
        <td><span style="font-family:monospace;font-size:12px">${maskMobile(f.mobile)}</span></td>

function fmtNum(n) { return n ? parseInt(n).toLocaleString('en-IN') : '0'; }
function maskMobile(m) { if(!m) return '—'; const s=m.replace(/\D/g,''); return s.length>=10 ? s.slice(0,2)+'****'+s.slice(-4) : m; }
function fmtDate(d) { if(!d) return '—'; try { return new Date(d).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}); } catch(e){return d;} }
function isToday(d) { if(!d) return false; const t=new Date(); const dt=new Date(d); return t.toDateString()===dt.toDateString(); }
function timeAgo(d) {
  if(!d) return '—';
  const diff = (Date.now()-new Date(d))/1000;
  if(diff<60) return 'just now';
  if(diff<3600) return Math.round(diff/60)+'m ago';
  if(diff<86400) return Math.round(diff/3600)+'h ago';
  if(diff<604800) return Math.round(diff/86400)+'d ago';
  return fmtDate(d);
}

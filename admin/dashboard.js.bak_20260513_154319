function getWcProducts() {
  const map = {
    'ld_wc_ccod':'cc_od', 'ld_wc_dlod':'dlod', 'ld_wc_term':'term_loan',
    'ld_wc_bg':'bg', 'ld_wc_lc':'lc', 'ld_wc_epc':'epc',
    'ld_wc_pcfc':'pcfc', 'ld_wc_others':'others'
  };
  const selected = [];
  Object.entries(map).forEach(([id, val]) => {
    if (document.getElementById(id)?.checked) {
      if (val === 'others') {
        const txt = document.getElementById('ld_wc_others_text')?.value?.trim();
        if (txt) selected.push('others:' + txt);
        else selected.push('others');
      } else {
        selected.push(val);
      }
    }
  });
  return selected.join(',');
}

function setWcProducts(val) {
  const map = {
    'cc_od':'ld_wc_ccod', 'dlod':'ld_wc_dlod', 'term_loan':'ld_wc_term',
    'bg':'ld_wc_bg', 'lc':'ld_wc_lc', 'epc':'ld_wc_epc',
    'pcfc':'ld_wc_pcfc'
  };
  // Reset all
  Object.values(map).forEach(id => { const el = document.getElementById(id); if(el) el.checked = false; });
  const othersEl = document.getElementById('ld_wc_others');
  const othersWrap = document.getElementById('ld_wc_others_wrap');
  const othersText = document.getElementById('ld_wc_others_text');
  if(othersEl) othersEl.checked = false;
  if(othersWrap) othersWrap.style.display = 'none';
  if(!val) return;
  val.split(',').forEach(v => {
    v = v.trim();
    if (map[v]) {
      const el = document.getElementById(map[v]);
      if(el) el.checked = true;
    } else if (v.startsWith('others')) {
      if(othersEl) othersEl.checked = true;
      if(othersWrap) othersWrap.style.display = 'block';
      const txt = v.includes(':') ? v.split(':').slice(1).join(':') : '';
      if(othersText) othersText.value = txt;
    }
  });
}

  const btn = document.querySelector('[onclick="saveDualProduct('+num+')"]');
  const otherBtn = document.querySelector('[onclick="saveDualProduct('+(num===1?2:1)+')"]');
  if (btn) { btn.disabled = true; btn.innerHTML = '<div class="spinner"></div> Saving...'; }
  let text = document.getElementById('policyText').value.trim();
  try {
    let r = await fetch('/api/admin/policy_parser.php', {
      method:'POST', headers:{'Content-Type':'application/json','X-Admin-Key':'WM_ADMIN_2025'},
      body: JSON.stringify({action:'save', fields:data, existing_id:0, raw_text:text})
    }).then(d=>d.json());
    if (r.type === 'created') {
      toast('\u2705 Product ' + num + ' saved! ID: ' + r.id, 'success');
      if (btn) { btn.innerHTML = '\u2705 Saved (ID: '+r.id+')'; btn.style.background = 'var(--green)'; }

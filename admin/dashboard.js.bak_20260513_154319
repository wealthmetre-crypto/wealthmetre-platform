
// ═══ STATE ═══
const API = '/api/admin/dashboard.php';
const AUTH = '/api/admin/auth.php';
let currentPage = 'dashboard';
let charts = {};
let user = {};

// ═══ INIT ═══
document.addEventListener('DOMContentLoaded', async () => {
  await checkAuth();
  setGreeting();
  loadDashboard();
  loadOverdueBadge();
});

async function checkAuth() {
  try {
    const r = await fetch(AUTH + '?action=check', {credentials:'include'});
    const d = await r.json();
    if (!d.success) { window.location.href = '/admin/owner_login.html'; return; }
    let user = d.data;
    document.getElementById('sbName').textContent = user.name;
    document.getElementById('sbRole').textContent = user.role;
    document.getElementById('sbAvatar').textContent = user.name.charAt(0).toUpperCase();
    document.getElementById('tbName').textContent = user.name.split(' ')[0];
    document.getElementById('tbAvatar').textContent = user.name.charAt(0).toUpperCase();
    document.getElementById('ownerName').value = user.name;
    document.getElementById('ownerEmail').value = user.email;
  } catch(e) { window.location.href = '/admin/owner_login.html'; }
}

async function doLogout() {
  await fetch(AUTH, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'logout'})});
  window.location.href = '/admin/owner_login.html';
}

function setGreeting() {
  const h = new Date().getHours();
  const g = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
  document.getElementById('dashGreeting').textContent = g + " — here's your business overview";
}

// ═══ NAVIGATION ═══
const pageTitles = {
  dashboard:'Dashboard', partners:'Partner Management', telecallers:'Telecaller Management',
  batches:'Lead Sheets', leads:'CRM Leads', followups:'Follow-ups',
  diva:'Diva AI Monitor', lenders:'Lender Intelligence', parser:'AI Policy Parser',
  dataquality:'Data Quality', testmatch:'Test Matching', smsharing:'SM Sharing',
  whatsapp:'WhatsApp Monitor', reports:'Reports', auditlogs:'Audit Logs',
  notifications:'Notifications', settings:'Settings', deploy:'Deploy'
};

function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-link').forEach(l => l.classList.remove('active'));
  const pg = document.getElementById('page-' + id);
  if (pg) pg.classList.add('active');
  const lk = document.querySelector('.sb-link[onclick*="' + id + '"]');
  if (lk) lk.classList.add('active');
  document.getElementById('tbTitle').textContent = pageTitles[id] || id;
  let currentPage = id;
  closeSidebar();
  // Lazy load
  if (id === 'partners') loadPartners();
  if (id === 'telecallers') loadTelecallers();
  if (id === 'batches') loadBatches();
  if (id === 'leads') { loadLeads(); populatePartnerFilter(); }
  if (id === 'lenders') loadLenders();
  if (id === 'diva') loadDiva();
  if (id === 'dataquality') loadDataQuality();
  if (id === 'auditlogs') loadAuditLogs();
  if (id === 'smsharing') loadSMDirectory();
}

// ═══ SIDEBAR MOBILE ═══
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sbOverlay').classList.toggle('show');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sbOverlay').classList.remove('show');
}

// ═══ DASHBOARD ═══
async function loadDashboard() {
  renderStatSkeletons();
  try {
    const [sumRes, chartRes, actRes] = await Promise.all([
      fetch(API + '?action=summary', {credentials:'include'}).then(r=>r.json()),
      fetch(API + '?action=charts', {credentials:'include'}).then(r=>r.json()),
      fetch(API + '?action=activity', {credentials:'include'}).then(r=>r.json())
    ]);
    if (sumRes.success) renderStats(sumRes.data);
    if (chartRes.success) renderCharts(chartRes.data);
    if (actRes.success) renderActivity(actRes.data);
  } catch(e) { toast('Failed to load dashboard', 'error'); }
}

function renderStatSkeletons() {
  const s1 = document.getElementById('statsRow1');
  const s2 = document.getElementById('statsRow2');
  s1.innerHTML = Array(5).fill('<div class="stat-card skeleton" style="height:95px"></div>').join('');
  s2.innerHTML = Array(5).fill('<div class="stat-card skeleton" style="height:95px"></div>').join('');
}

function renderStats(d) {
  const cards1 = [
    {icon:'fa-handshake',ic:'ic-navy',val:d.total_partners,lbl:'Total Partners',sub:d.active_partners+' active'},
    {icon:'fa-headset',ic:'ic-teal',val:d.total_telecallers,lbl:'Total Telecallers',sub:d.active_telecallers+' active'},
    {icon:'fa-users',ic:'ic-green',val:fmtNum(d.total_leads),lbl:'Total Leads',sub:'All time'},
    {icon:'fa-file-lines',ic:'ic-purple',val:d.total_batches,lbl:'Lead Batches',sub:d.active_batches+' active'},
    {icon:'fa-building-columns',ic:'ic-orange',val:d.active_lenders,lbl:'Active Lenders',sub:d.total_lenders+' total'},
  ];
  const cards2 = [
    {icon:'fa-phone',ic:'ic-navy',val:fmtNum(d.calls_today),lbl:'Calls Today',sub:'Updated leads'},
    {icon:'fa-thumbs-up',ic:'ic-green',val:fmtNum(d.interested_leads),lbl:'Interested (All)',sub:'Qualified leads'},
    {icon:'fa-calendar-day',ic:'ic-orange',val:d.followups_today,lbl:'Follow-ups Today',sub:'Due today'},
    {icon:'fa-triangle-exclamation',ic:'ic-red',val:d.followups_overdue,lbl:'Overdue',sub:'Need attention',alert:d.followups_overdue>0},
    {icon:'fa-robot',ic:'ic-purple',val:fmtNum(d.diva_today),lbl:'Diva Sessions Today',sub:fmtNum(d.diva_total)+' total'},
  ];
  document.getElementById('statsRow1').innerHTML = cards1.map(c => statCard(c)).join('');
  document.getElementById('statsRow2').innerHTML = cards2.map(c => statCard(c)).join('');
  // Update sidebar overdue badge
  const ob = document.getElementById('sbOverdueCount');
  if (d.followups_overdue > 0) { ob.textContent = d.followups_overdue; ob.style.display='inline'; }
  else ob.style.display='none';
  // Followups page stats
  if (document.getElementById('fupToday')) {
    document.getElementById('fupToday').textContent = d.followups_today || 0;
    document.getElementById('fupOverdue').textContent = d.followups_overdue || 0;
  }
}

function statCard(c) {
  return `<div class="stat-card" style="cursor:default">
    <div class="ic ${c.ic}" ${c.alert?'style="background:#fef2f2;color:#dc2626"':''}><i class="fa ${c.icon}"></i></div>
    <div class="val">${c.val ?? '—'}</div>
    <div class="lbl">${c.lbl}</div>
    ${c.sub ? `<div class="delta" style="color:var(--muted)">${c.sub}</div>` : ''}
  </div>`;
}

function renderCharts(d) {
  const colors = {
    navy:'rgba(30,58,138,.8)', navy2:'rgba(30,77,183,.8)',
    orange:'rgba(255,152,0,.8)', green:'rgba(22,163,74,.8)',
    teal:'rgba(13,148,136,.8)', purple:'rgba(124,58,237,.8)',
    red:'rgba(220,38,38,.8)', amber:'rgba(217,119,6,.8)',
    pink:'rgba(219,39,119,.8)'
  };
  const cArr = [colors.navy,colors.teal,colors.orange,colors.green,colors.purple,colors.red,colors.amber,colors.pink];

  // Daily calls
  if (d.dailyCalls && d.dailyCalls.length) {
    destroyChart('chartDailyCalls');
    charts.dailyCalls = new Chart(document.getElementById('chartDailyCalls'), {
      type: 'line',
      data: {
        labels: d.dailyCalls.map(r => fmtDate(r.date)),
        datasets: [{label:'Calls',data:d.dailyCalls.map(r=>r.count),borderColor:colors.navy,backgroundColor:'rgba(30,58,138,.08)',fill:true,tension:.4,pointBackgroundColor:colors.navy,pointRadius:4}]
      },
      options: chartOpts('Calls per day')
    });
  }

  // Funnel
  if (d.funnel && d.funnel.length) {
    destroyChart('chartFunnel');
    charts.funnel = new Chart(document.getElementById('chartFunnel'), {
      type: 'doughnut',
      data: {
        labels: d.funnel.map(r=>r.status),
        datasets: [{data:d.funnel.map(r=>r.count),backgroundColor:cArr,borderWidth:2}]
      },
      options: {...doughnutOpts()}
    });
  }

  // Lender types
  if (d.lenderTypes && d.lenderTypes.length) {
    destroyChart('chartLenders');
    charts.lenders = new Chart(document.getElementById('chartLenders'), {
      type: 'bar',
      data: {
        labels: d.lenderTypes.map(r=>r.lender_type.toUpperCase()),
        datasets: [{label:'Lenders',data:d.lenderTypes.map(r=>r.count),backgroundColor:[colors.navy,colors.orange,colors.teal,colors.purple]}]
      },
      options: chartOpts('Active lenders by type')
    });
  }

  // CIBIL
  if (d.cibilDist && d.cibilDist.length) {
    destroyChart('chartCibil');
    charts.cibil = new Chart(document.getElementById('chartCibil'), {
      type: 'bar',
      data: {
        labels: d.cibilDist.map(r=>r.range),
        datasets: [{label:'Leads',data:d.cibilDist.map(r=>r.count),backgroundColor:[colors.green,colors.navy,colors.amber,colors.orange,colors.red]}]
      },
      options: chartOpts('CIBIL score distribution')
    });
  }

  // Partner leads
  if (d.byPartner && d.byPartner.length) {
    destroyChart('chartPartnerLeads');
    charts.partnerLeads = new Chart(document.getElementById('chartPartnerLeads'), {
      type: 'bar',
      data: {
        labels: d.byPartner.map(r=>r.partner),
        datasets: [{label:'Leads',data:d.byPartner.map(r=>r.count),backgroundColor:colors.navy}]
      },
      options: {...chartOpts('Leads by partner'),indexAxis:'y'}
    });
  }
}

function chartOpts(title) {
  return {responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{}}},scales:{x:{grid:{display:false},ticks:{font:{size:10}}},y:{grid:{color:'rgba(0,0,0,.04)'},ticks:{font:{size:10}}}}};
}
function doughnutOpts() {
  return {responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{font:{size:10},boxWidth:10}}}};
}
function destroyChart(id) {
  if (charts[id]) { charts[id].destroy(); delete charts[id]; }
}

function renderActivity(feed) {
  const el = document.getElementById('activityFeed');
  if (!feed.length) { el.innerHTML = '<li style="padding:16px;text-align:center;color:var(--muted);font-size:12px">No recent activity</li>'; return; }
  const icColors = {blue:'ic-navy',purple:'ic-purple',green:'ic-green',orange:'ic-orange',red:'ic-red'};
  el.innerHTML = feed.slice(0,12).map(f => `
    <li class="feed-item">
      <div class="feed-ic ${icColors[f.color]||'ic-navy'}"><i class="fa ${f.icon}"></i></div>
      <div>
        <div class="feed-text">${f.text}</div>
        <div class="feed-time"><i class="fa fa-clock" style="margin-right:3px"></i>${timeAgo(f.time)}</div>
      </div>
    </li>`).join('');
}

async function loadActivity() {
  try {
    let r = await fetch(API + '?action=activity', {credentials:'include'}).then(d=>d.json());
    if (r.success) renderActivity(r.data);
  } catch(e){}
}

// ═══ PARTNERS ═══
async function loadPartners(page=1) {
  const tbody = document.getElementById('partnersTable');
  tbody.innerHTML = '<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--muted)"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>';
  const search = document.getElementById('partnerSearch')?.value||'';
  const status = document.getElementById('partnerStatus')?.value||'';
  try {
    let r = await fetch(`${API}?action=partners_list&page=${page}&search=${encodeURIComponent(search)}&status=${status}`, {credentials:'include'}).then(d=>d.json());
    if (!r.success) { tbody.innerHTML = '<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--red)">Failed to load partners</td></tr>'; return; }
    const rows = r.data;
    if (!rows.length) { tbody.innerHTML = '<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--muted)">No partners found</td></tr>'; return; }
    tbody.innerHTML = rows.map((p,i) => {
      const tier = p.lead_count > 200 ? 'Gold' : p.lead_count > 50 ? 'Silver' : 'Bronze';
      const tierBadge = tier==='Gold'?'b-gold':tier==='Silver'?'b-navy':'b-orange';
      const conv = p.lead_count > 0 ? Math.round((p.interested_count/p.lead_count)*100) : 0;
      const pname = p.name || p.partner_name || (p.first_name+' '+p.last_name) || '—';
      const pcity = p.city || p.branch_city || '—';
      const pmobile = p.display_mobile || p.mobile || p.phone || '—';
      return `<tr>
        <td style="color:var(--muted);font-size:11px">${(page-1)*25+i+1}</td>
        <td><div class="name-cell">${pname}</div><div class="sub-cell">${p.email||''}</div></td>
        <td>${pcity}</td>
        <td>${maskMobile(pmobile)}</td>
        <td style="text-align:center">${p.telecaller_count||0}</td>
        <td style="text-align:center">${fmtNum(p.lead_count||0)}</td>
        <td style="text-align:center"><span style="color:var(--green);font-weight:700">${p.interested_count||0}</span></td>
        <td style="text-align:center"><span style="color:${conv>10?'var(--green)':'var(--muted)'};font-weight:700">${conv}%</span></td>
        <td><span class="badge ${tierBadge}">${tier}</span></td>
        <td><span class="badge ${p.status==='active'?'b-active':'b-inactive'}">${p.status||'active'}</span></td>
        <td style="font-size:11px;color:var(--muted)">${p.last_login_at ? timeAgo(p.last_login_at) : 'Never'}</td>
        <td><div class="td-actions">
          <button class="btn btn-outline btn-xs" title="View Leads" onclick="viewPartnerLeads('${p.id}','${(p.partner_name||p.name||'').replace(/'/g,'')}')"><i class="fa fa-eye"></i></button>
          ${p.mobile||p.phone ? `<a href="https://wa.me/91${(p.mobile||p.phone||'').replace(/\D/g,'')}" target="_blank" class="btn btn-ghost btn-xs"><i class="fab fa-whatsapp"></i></a>` : ''}
        </div></td>
      </tr>`;
    }).join('');
    // Pagination
    let pg = r.pagination;
    document.getElementById('partnersInfo').textContent = `Showing ${(pg.page-1)*pg.per_page+1}–${Math.min(pg.page*pg.per_page,pg.total)} of ${pg.total} partners`;
    renderPagination('partnerPages', pg, loadPartners);
  } catch(e) { tbody.innerHTML = '<tr><td colspan="12" style="text-align:center;padding:24px;color:var(--red)">Error loading partners</td></tr>'; }
}


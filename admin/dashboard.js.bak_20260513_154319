    } else {
      renderParserFields(result);
      renderSpecialConditionsPanel(result.suggested_special_conditions || []);
      document.getElementById('parserActions').style.display = 'flex';
    }
    toast('Policy parsed successfully!', 'success');
  } catch(e) { toast('Parse error: ' + e.message, 'error'); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fa fa-wand-magic-sparkles"></i> Parse with AI';
}

async function renderDualProduct(data) {
  // Auto-find correct DB match for each product
  const lenderName = data.lender_name || '';
  const prod1Type = data.product_type || data.product || '';
  const sp = data.second_product || {};
  const prod2Type = sp.product || '';
  if (lenderName && prod1Type) {
    try {
      const r1 = await fetch(API+'?action=find_lender&name='+encodeURIComponent(lenderName)+'&product='+encodeURIComponent(prod1Type)).then(d=>d.json());
      if (r1.success && r1.data) data.matched_lender_id = r1.data.id;
    } catch(e){}
  }
  if (lenderName && prod2Type) {
    try {
      const r2 = await fetch(API+'?action=find_lender&name='+encodeURIComponent(lenderName)+'&product='+encodeURIComponent(prod2Type)).then(d=>d.json());
      if (r2.success && r2.data) { data.second_product.matched_lender_id = r2.data.id; sp.matched_lender_id = r2.data.id; }
    } catch(e){}
  }
  const pl = document.getElementById('parserPlaceholder');
  const pf = document.getElementById('parserFields');
  const pa = document.getElementById('parserActions');
  pl.style.display = 'none';
  pa.style.display = 'none';

  // sp already declared above
  // lenderName already declared above
  const prod1Name = data.product_type || data.product || 'Product 1';

  // Build product 2 data by merging base data with second_product overrides
  const prod2 = Object.assign({}, data, {
    product: sp.product,
    product_type: sp.product,
    matched_lender_id: sp.matched_lender_id || data.matched_lender_id,
    roi_min: sp.roi_min || null,
    roi_max: sp.roi_max || null,
    loan_min_lakh: sp.loan_min_lakh || null,
    loan_max_lakh: sp.loan_max_lakh || null,
    max_ltv: sp.max_ltv || data.max_ltv,
    second_product: null,
    dual_product_note: null
  });

  const skip = ['confidence_score','missing_fields','raw_text','human_review_required',
                'searchable_text','ltv_matrix','tenure_matrix','second_product','dual_product_note'];

  function fieldRows(d) {
    return Object.entries(d).filter(([k,v]) => !skip.includes(k) && v !== null && v !== undefined && v !== '')
      .map(([k,v]) => `<div style="display:flex;align-items:flex-start;padding:6px 0;border-bottom:1px solid var(--border);gap:8px">

<?php
declare(strict_types=1);

header('Content-Type: application/json');

require_once __DIR__ . '/../../config/db.php';

function json_out(array $data, int $code = 200): void {
    http_response_code($code);
    echo json_encode($data, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
    exit;
}

function db_conn(): mysqli {
    foreach (["mysqli","conn","db","connection"] as $v) {
        if (isset($GLOBALS[$v]) && $GLOBALS[$v] instanceof mysqli) {
            return $GLOBALS[$v];
        }
    }

    if (defined("DB_HOST")) {
        $host = DB_HOST;
        $user = defined("DB_USER") ? DB_USER : "";
        $pass = defined("DB_PASS") ? DB_PASS : "";
        $name = defined("DB_NAME") ? DB_NAME : "";
        $m = new mysqli($host, $user, $pass, $name);
        if ($m->connect_error) {
            json_out(["ok" => false, "error" => "DB connection failed: ".$m->connect_error], 500);
        }
        $m->set_charset("utf8mb4");
        return $m;
    }

    json_out(["ok" => false, "error" => "Could not detect DB connection. Check config/db.php"], 500);
}

function table_columns(mysqli $mysqli, string $table): array {
    $cols = [];
    $res = $mysqli->query("SHOW COLUMNS FROM `$table`");
    if (!$res) json_out(["ok" => false, "error" => "Cannot read table columns: ".$mysqli->error], 500);

    while ($r = $res->fetch_assoc()) {
        $cols[$r["Field"]] = $r;
    }
    return $cols;
}

function set_if_col(array &$row, array $cols, string $col, $val): void {
    if (isset($cols[$col])) $row[$col] = $val;
}

function insert_queue(mysqli $mysqli, array $cols, string $platform, string $caption, string $mediaUrl, string $mediaType, string $originalName, string $batchId): int {
    $now = date("Y-m-d H:i:s");
    $title = mb_substr(trim($caption) !== "" ? trim($caption) : "Universal Media Upload", 0, 180);

    $row = [];

    set_if_col($row, $cols, "content_type", $platform);
    set_if_col($row, $cols, "status", "needs_review");

    set_if_col($row, $cols, "title", $title);
    set_if_col($row, $cols, "topic", $title);
    set_if_col($row, $cols, "slug", "universal-media-" . $platform . "-" . date("Ymd-His"));
    set_if_col($row, $cols, "city", "");
    set_if_col($row, $cols, "target_keyword", "Universal Media Upload");

    set_if_col($row, $cols, "caption", $caption);
    set_if_col($row, $cols, "meta_text", $caption);
    set_if_col($row, $cols, "meta_description", $caption);
    set_if_col($row, $cols, "content", $caption);
    set_if_col($row, $cols, "body", $caption);
    set_if_col($row, $cols, "generated_content", $caption);
    set_if_col($row, $cols, "post_text", $caption);
    set_if_col($row, $cols, "social_caption", $caption);

    if ($mediaType === "image") {
        set_if_col($row, $cols, "creative_image_url", $mediaUrl);
    }

    set_if_col($row, $cols, "creative_media_url", $mediaUrl);
    set_if_col($row, $cols, "creative_media_type", $mediaType);
    set_if_col($row, $cols, "uploaded_media_original_name", $originalName);
    set_if_col($row, $cols, "universal_batch_id", $batchId);

    if ($platform === "instagram") {
        set_if_col($row, $cols, "creative_status", "uploaded");
        set_if_col($row, $cols, "instagram_publish_status", $mediaType === "video" ? "needs_video_support" : "not_published");
    }

    if ($platform === "facebook") {
        set_if_col($row, $cols, "facebook_publish_status", $mediaType === "video" ? "needs_video_support" : "not_published");
    }

    set_if_col($row, $cols, "platform_publish_note", $mediaType === "video" ? "Video uploaded. Publisher video support pending." : "Universal upload created.");
    set_if_col($row, $cols, "created_at", $now);
    set_if_col($row, $cols, "updated_at", $now);

    if (!isset($row["content_type"]) || !isset($row["status"])) {
        json_out(["ok" => false, "error" => "content_queue must have content_type and status columns"], 500);
    }

    $fields = array_keys($row);
    $placeholders = implode(",", array_fill(0, count($fields), "?"));
    $sql = "INSERT INTO content_queue (`" . implode("`,`", $fields) . "`) VALUES ($placeholders)";
    $stmt = $mysqli->prepare($sql);

    if (!$stmt) {
        json_out(["ok" => false, "error" => "Prepare failed: ".$mysqli->error, "sql" => $sql], 500);
    }

    $types = str_repeat("s", count($fields));
    $values = array_values($row);
    $stmt->bind_param($types, ...$values);

    if (!$stmt->execute()) {
        json_out(["ok" => false, "error" => "Insert failed: ".$stmt->error], 500);
    }

    return (int)$stmt->insert_id;
}


function update_existing_queue_media(mysqli $mysqli, array $cols, int $queueId, string $mediaUrl, string $mediaType, string $originalName, string $batchId): array {
    if ($queueId <= 0) {
        json_out(["ok" => false, "error" => "Invalid existing_queue_id"], 422);
    }

    $check = $mysqli->prepare("SELECT id, content_type, title, topic, status FROM content_queue WHERE id=? LIMIT 1");
    if (!$check) {
        json_out(["ok" => false, "error" => "Prepare failed: ".$mysqli->error], 500);
    }

    $check->bind_param("i", $queueId);
    $check->execute();
    $res = $check->get_result();
    $existing = $res ? $res->fetch_assoc() : null;

    if (!$existing) {
        json_out(["ok" => false, "error" => "content_queue row not found for existing_queue_id=".$queueId], 404);
    }

    $updates = [];
    $types = "";
    $values = [];

    $add = function(string $col, $val) use (&$updates, &$types, &$values, $cols) {
        if (isset($cols[$col])) {
            $updates[] = "`$col`=?";
            $types .= "s";
            $values[] = (string)$val;
        }
    };

    $add("creative_media_url", $mediaUrl);
    $add("creative_media_type", $mediaType);
    $add("uploaded_media_original_name", $originalName);
    $add("universal_batch_id", $batchId);
    $add("creative_status", "uploaded");
    $add("platform_publish_note", $mediaType === "video" ? "Final creative attached. Video publishing support pending." : "Final creative attached to existing generated post.");

    if ($mediaType === "image") {
        $add("creative_image_url", $mediaUrl);
        $add("instagram_image_url", $mediaUrl);
    }

    if (isset($cols["updated_at"])) {
        $updates[] = "`updated_at`=NOW()";
    }

    if (!$updates) {
        json_out(["ok" => false, "error" => "No media columns found to update"], 500);
    }

    $sql = "UPDATE content_queue SET " . implode(", ", $updates) . " WHERE id=? LIMIT 1";
    $types .= "i";
    $values[] = $queueId;

    $stmt = $mysqli->prepare($sql);
    if (!$stmt) {
        json_out(["ok" => false, "error" => "Prepare failed: ".$mysqli->error, "sql" => $sql], 500);
    }

    $stmt->bind_param($types, ...$values);

    if (!$stmt->execute()) {
        json_out(["ok" => false, "error" => "Update failed: ".$stmt->error], 500);
    }

    return [
        "id" => $queueId,
        "content_type" => $existing["content_type"] ?? "",
        "title" => $existing["title"] ?? "",
        "topic" => $existing["topic"] ?? "",
        "status" => $existing["status"] ?? ""
    ];
}

if ($_SERVER["REQUEST_METHOD"] !== "POST") {
    json_out(["ok" => false, "error" => "POST required"], 405);
}

$caption = trim((string)($_POST["caption"] ?? ""));
$existingQueueId = (int)($_POST["existing_queue_id"] ?? $_POST["queue_id"] ?? 0);
$platformsRaw = $_POST["platforms"] ?? [];

if (is_string($platformsRaw)) {
    $platformsRaw = explode(",", $platformsRaw);
}

$platforms = [];
foreach ((array)$platformsRaw as $p) {
    $p = strtolower(trim((string)$p));
    if (in_array($p, ["facebook", "instagram"], true)) $platforms[] = $p;
}
$platforms = array_values(array_unique($platforms));

if (!$platforms) {
    json_out(["ok" => false, "error" => "Select Facebook and/or Instagram"], 422);
}

if (!isset($_FILES["media"]) || !is_uploaded_file($_FILES["media"]["tmp_name"])) {
    json_out(["ok" => false, "error" => "Media file required"], 422);
}

$file = $_FILES["media"];

if ($file["error"] !== UPLOAD_ERR_OK) {
    json_out(["ok" => false, "error" => "Upload error code: ".$file["error"]], 422);
}

$maxBytes = 100 * 1024 * 1024;
if ((int)$file["size"] > $maxBytes) {
    json_out(["ok" => false, "error" => "File too large. Max 100 MB allowed."], 422);
}

$finfo = new finfo(FILEINFO_MIME_TYPE);
$mime = $finfo->file($file["tmp_name"]) ?: "";

$allowed = [
    "image/jpeg" => ["ext" => "jpg", "type" => "image"],
    "image/png"  => ["ext" => "png", "type" => "image"],
    "image/webp" => ["ext" => "webp", "type" => "image"],
    "image/gif"  => ["ext" => "gif", "type" => "image"],
    "video/mp4"  => ["ext" => "mp4", "type" => "video"],
    "video/quicktime" => ["ext" => "mov", "type" => "video"],
    "video/webm" => ["ext" => "webm", "type" => "video"],
];

if (!isset($allowed[$mime])) {
    json_out(["ok" => false, "error" => "Unsupported media type: ".$mime], 422);
}

$mediaType = $allowed[$mime]["type"];
$ext = $allowed[$mime]["ext"];

$uploadDir = __DIR__ . "/../../uploads/social/universal";
if (!is_dir($uploadDir)) {
    mkdir($uploadDir, 0775, true);
}

$batchId = "um_" . date("Ymd_His") . "_" . bin2hex(random_bytes(4));
$filename = $batchId . "." . $ext;
$target = $uploadDir . "/" . $filename;

if (!move_uploaded_file($file["tmp_name"], $target)) {
    json_out(["ok" => false, "error" => "Could not move uploaded file"], 500);
}

@chmod($target, 0664);

$mediaPath = "/uploads/social/universal/" . $filename;
$scheme = "https";
$host = $_SERVER["HTTP_HOST"] ?? "wealthmetre.com";
$mediaUrl = $scheme . "://" . $host . $mediaPath;

$mysqli = db_conn();
$cols = table_columns($mysqli, "content_queue");

if ($existingQueueId > 0) {
    $updated = update_existing_queue_media($mysqli, $cols, $existingQueueId, $mediaUrl, $mediaType, (string)$file["name"], $batchId);

    json_out([
        "ok" => true,
        "mode" => "attach_existing",
        "message" => "Final creative attached to existing post.",
        "media_url" => $mediaUrl,
        "media_type" => $mediaType,
        "batch_id" => $batchId,
        "updated" => $updated
    ]);
}

$created = [];
foreach ($platforms as $platform) {
    $created[] = [
        "platform" => $platform,
        "id" => insert_queue($mysqli, $cols, $platform, $caption, $mediaUrl, $mediaType, (string)$file["name"], $batchId)
    ];
}

json_out([
    "ok" => true,
    "mode" => "quick_upload",
    "message" => "Universal media uploaded and platform posts created for review.",
    "media_url" => $mediaUrl,
    "media_type" => $mediaType,
    "batch_id" => $batchId,
    "created" => $created
]);
